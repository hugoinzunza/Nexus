# Credenciales del colector del Diario (corre en el Mac mini).
# Copia este archivo a deploy/collector.env (o ~/.nexus/binance.env) y completa
# los valores reales. El archivo real NO se commitea (está en .gitignore).
#
#   cp deploy/collector.env.example deploy/collector.env
#   # luego edita deploy/collector.env con tus valores
#
# Permisos de la API key en Binance:
#   ✅ Enable Reading  (para Spot)
#   ✅ Enable Futures  (para Futuros USDⓈ-M — no hay "solo lectura" aparte)
#   ⛔ Enable Withdrawals  -> SIEMPRE desactivado
#   Restringe la key por IP a la IP pública del Mac mini.

BINANCE_API_KEY=tu_api_key_aqui
BINANCE_API_SECRET=tu_api_secret_aqui

# URL completa del endpoint de ingesta en Railway (incluye la ruta):
NEXUS_INGEST_URL=https://web-production-2e4bd.up.railway.app/m/journal/api/ingest

# Token compartido con Railway (mismo valor en la env var NEXUS_INGEST_TOKEN de Railway):
NEXUS_INGEST_TOKEN=pega_aqui_el_token_de_ingesta

# Opcional: días de historial a traer (por defecto 365).
BINANCE_LOOKBACK_DAYS=365
