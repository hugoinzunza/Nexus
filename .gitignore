# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Configuración local con datos sensibles (claves de API, tokens, etc.)
config/local.json
*.local.json
.env
*.env
!*.env.example
deploy/collector.env

# Sistema operativo
.DS_Store

# Logs
*.log
logs/

# Datos en runtime (sensibles / efímeros): NO se versionan.
#   journal_income.json, push_subs.json, setups.json, vix_1d.json, etc.
# Pero la HISTORIA de velas (klines_*.json) SÍ se versiona: Railway está
# geo-bloqueado de Binance (HTTP 451), así que la única forma de que producción
# tenga años de estructura para los POIs profundos es traerla en el deploy.
data/*
!data/klines_*.json

# Worktrees temporales de agentes Claude
.claude/worktrees/
